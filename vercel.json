{
    "version": 2,
    "builds": [
        {
            "src": "api/**/*.go",
            "use": "@vercel/go"
        }
    ],
    "routes": [
        {
            "src": "/api/mascot",
            "dest": "/api/mascot.go"
        },
        {
            "src": "/api/click",
            "dest": "/api/click.go"
        }
    ]
}